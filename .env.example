# Local Docker / CI: copy to .env (e.g. ./run setup). WEB_SERVER_* and PHP_MYADMIN_* map to docker-compose port bindings.
# Local run ready to use (./run env) to copy .env.example to .env.
# After copying to .env for local use, you usually only need to set the mail variables (MAIL_*) by hand.
APP_NAME=E-Museu

APP_KEY=

WEB_SERVER_PORT_LOCAL=9090
WEB_SERVER_PORT_PROD_LOCAL=9091

# DEVELOPMENT / LOCAL values (always set these values here on .env.example before committing to test CI):

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:${WEB_SERVER_PORT_LOCAL}

# LOCAL PRODUCTION values (prod-local):

# APP_ENV=production
# APP_DEBUG=false
# APP_URL=http://localhost:${WEB_SERVER_PORT_PROD_LOCAL}

# STAGING values (same as prod-local, but with staging auth protection):

# APP_ENV=staging
# APP_DEBUG=true
# APP_URL=http://localhost:${WEB_SERVER_PORT_PROD_LOCAL}

# Mail: default mailer is `resend` (config/mail.php) → RESEND_KEY in config/services.php.
# OutgoingMailIsConfigured gates public verification e-mails when the default mailer is not ready.
# Required for production-like outbound mail: MAIL_MAILER, RESEND_KEY (if using resend), MAIL_FROM_ADDRESS, MAIL_FROM_NAME.
# PHPUnit (phpunit.xml) forces MAIL_MAILER=array — do not rely on Resend in automated tests.
MAIL_MAILER=resend
RESEND_KEY=
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_LOG_CHANNEL / MAIL_MARKDOWN_THEME: config/mail.php when using log mailer or markdown mail.

# LOG_CHANNEL / LOG_LEVEL: config/logging.php → Monolog (stack → single writes storage/logs/laravel.log).
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# LOG_SLACK_WEBHOOK_URL= — config/logging.php slack channel when LOG_CHANNEL includes slack.

PHP_MYADMIN_PORT_LOCAL=9092

# MySQL: config/database.php connections.mysql — Eloquent/Query Builder. docker-compose service name `db` as DB_HOST.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=user
DB_PASSWORD=user
DB_ROOT_PASSWORD=secret
# DB_SOCKET= — unix_socket on the mysql connection (local MySQL without TCP).
# MYSQL_ATTR_SSL_CA= — PDO MySQL SSL CA path when config/database.php builds mysql options (PHP 8.5+ safe attr).

# Deployed apps (Coolify, etc.) often use DATABASE_URL instead of DB_*; Laravel merges URL with connection config.
# DATABASE_URL=mysql://user:your_password@db:3306/laravel

# Redis: config/database.php (redis.default / redis.cache) — phpredis client. Session store: config/session.php; app cache store: config/cache.php.
# Public catalog flow stores pending verification in session (CollaboratorService); with redis session driver that data lives in this store.
# REDIS_URL → ConfigurationUrlParser in Illuminate\Redis\RedisManager; without it, REDIS_HOST / REDIS_PORT / REDIS_PASSWORD build the connection.
REDIS_URL=
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_USERNAME=
# REDIS_DB / REDIS_CACHE_DB: logical Redis database index for default vs cache connection (config/database.php redis.default / redis.cache).
REDIS_DB=0
REDIS_CACHE_DB=1
# REDIS_CLUSTER / REDIS_PREFIX: config/database.php redis.options — cluster mode and key prefix (prefix defaults from Str::slug(APP_NAME)).

# BROADCAST_DRIVER: config/broadcasting.php — null (default) disables broadcasting; use log to record attempts in logs.
BROADCAST_DRIVER=null

# Session + application cache both use the redis connection above (config/session.php, config/cache.php → Redis store).
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
SESSION_DRIVER=redis
SESSION_LIFETIME=120
# SESSION_CONNECTION / SESSION_STORE: config/session.php — use a non-default redis connection or cache store name when needed.
SESSION_CONNECTION=
SESSION_STORE=
# SESSION_DOMAIN / SESSION_SECURE_COOKIE: config/session.php cookie scope and Secure flag (HTTPS).
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=
# CACHE_PREFIX: config/cache.php — override Redis/file cache key prefix (default: APP_NAME slug + _cache_).
CACHE_PREFIX=

# QUEUE_CONNECTION: config/queue.php — sync runs jobs inline; database/redis require workers (php artisan queue:work).
QUEUE_CONNECTION=sync

# S3 / MinIO: config/filesystems.php disks public + s3 when FILESYSTEM_DISK=s3. Flysystem AWS adapter; use_path_style_endpoint defaults true there (MinIO-friendly).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
# AWS_DEFAULT_REGION / AWS_USE_PATH_STYLE_ENDPOINT: config/filesystems.php — override region or force virtual-hosted style for native AWS S3.
AWS_DEFAULT_REGION=
AWS_USE_PATH_STYLE_ENDPOINT=

# Vite: vite.config.js loadEnv — dev server origin, HMR host/port, optional VITE_CORS_EXTRA_ORIGINS for extra browser origins hitting the dev server.
VITE_DEV_ORIGIN=http://localhost:5173
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5173
# VITE_CORS_EXTRA_ORIGINS=http://127.0.0.1:9090

# When APP_ENV=staging: StagingBasicAuth + config/auth.php staging guard read these for HTTP Basic in front of the app.
STAGING_HTTP_USER=staging
STAGING_HTTP_PASSWORD=set_a_password

# SANCTUM_STATEFUL_DOMAINS / SANCTUM_TOKEN_PREFIX: config/sanctum.php — SPA / cookie session auth across subdomains.
SANCTUM_STATEFUL_DOMAINS=
SANCTUM_TOKEN_PREFIX=

# BCRYPT_ROUNDS: config/hashing.php — bcrypt cost (default 12 when unset).
# BCRYPT_ROUNDS=12

# DEBUGBAR_ENABLED / DEBUGBAR_EDITOR / IGNITION_*: config/debugbar.php — require-dev; DEBUGBAR_ENABLED null = auto from APP_DEBUG.
# DEBUGBAR_ENABLED=true
# DEBUGBAR_EDITOR=phpstorm

# ASSET_URL: config/app.php asset_url — optional CDN/base URL for published Mix/Vite asset URLs.
ASSET_URL=

# Coolify env templates (paste-friendly): deploy/coolify-production.env.example, deploy/coolify-staging.env.example
