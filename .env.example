# Local Docker / CI: copy to .env (e.g. ./run setup). WEB_SERVER_* and PHP_MYADMIN_* map to docker-compose port bindings.
# Local run ready to use (./run env) to copy .env.example to .env.
# After copying to .env, set APP_KEY, DB_* and secrets; see MAIL_* below (MAIL_MAILER=log for local log driver).
APP_NAME=E-Museu-Local

APP_KEY=



WEB_SERVER_PORT_LOCAL=9090
WEB_SERVER_PORT_PROD_LOCAL=9091



# DEVELOPMENT / LOCAL values (always set these values here on .env.example before committing to test CI):

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:${WEB_SERVER_PORT_LOCAL}


# LOCAL PRODUCTION values (prod-local):

# APP_ENV=production
# APP_DEBUG=false
# APP_URL=http://localhost:${WEB_SERVER_PORT_PROD_LOCAL}

# STAGING values (same as prod-local, but with staging auth protection):

# APP_ENV=staging
# APP_DEBUG=true
# APP_URL=http://localhost:${WEB_SERVER_PORT_PROD_LOCAL}



# APP_FORCE_HTTPS: config/app.php force_https — force HTTPS on the app URL (default false).
APP_FORCE_HTTPS=false # Default


MAIL_PUBLIC_CONTRIBUTION_EMAIL_VERIFICATION_ENABLED=false # Default
# MAIL_PUBLIC_CONTRIBUTION_EMAIL_VERIFICATION_ENABLED=true
MAIL_PASSWORD=
MAIL_HOST=smtp.utfpr.edu.br # Default
MAIL_PORT=587 # Default
MAIL_USERNAME=e-museu-gp@utfpr.edu.br # Default
MAIL_FROM_ADDRESS=e-museu-gp@utfpr.edu.br # Default
MAIL_FROM_NAME="${APP_NAME}" # Default
MAIL_MARKDOWN_THEME=default # Default
MAIL_MAILER=smtp # Default you can use " log " for local development



LOG_CHANNEL=stack # Default
LOG_DEPRECATIONS_CHANNEL=null # Default
LOG_LEVEL=debug # Default



PHP_MYADMIN_PORT_LOCAL=9092 # Docker Compose (this repo)



# DATABASE_URL: config/database.php DATABASE_URL (MySQL DSN) Coolify.
DATABASE_URL=
DB_CONNECTION=mysql # Default
DB_HOST=db # Docker Compose service name
DB_PORT=3306 # Default
DB_DATABASE=laravel # Docker Compose example database
DB_USERNAME=user # Docker Compose example user
DB_PASSWORD=user # Docker Compose example password
DB_ROOT_PASSWORD=secret # Docker Compose MySQL root (init scripts)



# REDIS_URL: config/database.php REDIS_URL (Redis DSN) Coolify.
REDIS_URL=
REDIS_CLIENT=phpredis # Default
REDIS_HOST=redis # Docker Compose service name
REDIS_PORT=6379 # Default
REDIS_PASSWORD=null
REDIS_USERNAME=default
REDIS_DB=0 # Default
REDIS_CACHE_DB=1 # Default



BROADCAST_DRIVER=null # Default



CACHE_DRIVER=redis # Default
FILESYSTEM_DISK=local # Default
SESSION_DRIVER=redis # Default
SESSION_LIFETIME=120 # Default
# optional:
SESSION_CONNECTION=
# optional:
SESSION_STORE=
# optional:
SESSION_DOMAIN=
# optional:
SESSION_SECURE_COOKIE=
# optional:
CACHE_PREFIX=



QUEUE_CONNECTION=sync # Default


# Necessary for S3 storage, coolify
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_DEFAULT_REGION=
# optional:
AWS_USE_PATH_STYLE_ENDPOINT=



VITE_DEV_ORIGIN=http://localhost:5173 # Default (vite.config.js fallback)
VITE_HMR_HOST=localhost # Default
VITE_HMR_PORT=5173 # Default



# Only used in staging environment:
STAGING_HTTP_USER=staging
STAGING_HTTP_PASSWORD=set_a_password



# optional:
SANCTUM_STATEFUL_DOMAINS=
# optional:
SANCTUM_TOKEN_PREFIX=



# optional:
ASSET_URL=


# To activate turnstile, uncomment the following lines and set the TURNSTILE_SITE_KEY and TURNSTILE_SECRET_KEY.
ANTIBOT_DRIVER=null # Default
# ANTIBOT_DRIVER=turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
ANTIBOT_RESPONSE_INPUT=cf-turnstile-response # Default
ANTIBOT_VERIFICATION_REQUEST_RESPONSE_INPUT=cf_turnstile_response_request_verify # Default
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify # Default



# Admin AI: translation when at least one provider block is enabled (below) with *_TOKEN / *_API_KEY plus models.
# Chain order: comma-separated keys matching config/ai.php sections (default openrouter,groq,github_models).
AI_CHAT_COMPLETION_CHAIN=groq,openrouter,github_models # Default

# Groq: second in chain after OpenRouter on recoverable failures. Requires GROQ_API_KEY when enabled.
GROQ_ENABLED=false # Default
# GROQ_ENABLED=true
GROQ_API_KEY=
GROQ_PROVIDER_URL=https://api.groq.com/openai/v1/chat/completions # Default
GROQ_MODELS=llama-3.1-8b-instant,gemma2-9b-it # Default
GROQ_TIMEOUT=90 # Default
GROQ_CONNECT_TIMEOUT=15 # Default
GROQ_TEMPERATURE=0.2 # Default
GROQ_MAX_TOKENS=2048 # Default
GROQ_LOG_LABEL=Groq # Default



OPENROUTER_ENABLED=false # Default
# OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=
# Full POST URL for chat completions (OpenAI-compatible).
OPENROUTER_PROVIDER_URL=https://openrouter.ai/api/v1/chat/completions # Default
# Comma-separated model ids; on failure (HTTP/parse) tries the next id, then Groq / GitHub if configured.
# Prefer openrouter/free first (pooled free tier); add specific :free models as fallbacks.
OPENROUTER_MODELS=openrouter/free,meta-llama/llama-3.2-3b-instruct:free # Default
OPENROUTER_TIMEOUT=90 # Default
OPENROUTER_CONNECT_TIMEOUT=15 # Default
OPENROUTER_TEMPERATURE=0.2 # Default
OPENROUTER_MAX_TOKENS=2048 # Default
# Name shown in admin translation UI for this block (same value is used as the human-readable log label).
OPENROUTER_LOG_LABEL=OpenRouter # Default



# GitHub Models (last). PAT with "models" scope: https://github.com/settings/tokens — https://docs.github.com/en/github-models/quickstart
GITHUB_MODELS_ENABLED=false # Default
# GITHUB_MODELS_ENABLED=true
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_PROVIDER_URL=https://models.github.ai/inference/chat/completions # Default
GITHUB_MODELS_API_VERSION=2022-11-28 # Default
GITHUB_MODELS_ACCEPT=application/vnd.github+json # Default
# Comma-separated; first model is tried, then the next on recoverable failure (e.g. another publisher).
GITHUB_MODELS=openai/gpt-4o-mini,meta/meta-llama-3.1-8b-instruct # Default
GITHUB_MODELS_TIMEOUT=90 # Default
GITHUB_MODELS_CONNECT_TIMEOUT=15 # Default
GITHUB_MODELS_TEMPERATURE=0.2 # Default
GITHUB_MODELS_MAX_TOKENS=2048 # Default
GITHUB_MODELS_LOG_LABEL="GitHub Models" # Default


AI_RATE_LIMIT_PER_MINUTE=5 # Default
# Max size of the serialized source block sent to the model: strlen() UTF-8 bytes (not grapheme count).
AI_TRANSLATION_MAX_SOURCE_CHARS=120000 # Default

# Coolify env templates (paste-friendly): docs/deploy/coolify-production.env.example, docs/deploy/coolify-staging.env.example
