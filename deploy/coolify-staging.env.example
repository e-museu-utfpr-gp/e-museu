APP_DEBUG=true
APP_ENV=staging
APP_FORCE_HTTPS=true
APP_KEY=
APP_NAME=E-Museu-Staging
APP_URL=https://YOUR_WEB_SERVICE.sslip.io
ASSET_URL=https://YOUR_WEB_SERVICE.sslip.io
AWS_ACCESS_KEY_ID=SERVICE_USER_S3
AWS_BUCKET=e-museu-staging
AWS_ENDPOINT=SERVICE_URL_S3_8333
AWS_SECRET_ACCESS_KEY=SERVICE_PASSWORD_S3
