DATABASE_URL=mysql://USER:PASSWORD@YOUR_MYSQL_HOST:3306/staging_e_museu
FILESYSTEM_DISK=s3
SESSION_SECURE_COOKIE=true
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=E-Museu-Staging
