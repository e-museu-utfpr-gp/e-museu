#!/bin/bash

set -o errexit
set -o pipefail

# After Docker chown, .env / .phpunit.result.cache on the host can be uid 82 (www-data). Put them back on the
# invoking user so the editor always works (honours SUDO_UID when using sudo ./run).
function fix_host_env_files_owner {
  local huid hgid f
  if [[ -n "${SUDO_UID:-}" ]]; then
    huid=$SUDO_UID
    hgid=${SUDO_GID:-$SUDO_UID}
  else
    huid=$(id -u)
    hgid=$(id -g)
  fi
  for f in .env .phpunit.result.cache; do
    if [ -f "$f" ]; then
      chown "$huid:$hgid" "$f" 2>/dev/null || true
      chmod 664 "$f" 2>/dev/null || true
    fi
  done
}

function env {
  local force=false
  for arg in "$@"; do
    case "$arg" in
      -f|--force) force=true ;;
    esac
  done

  echo ">> Ensuring environment file..."
  if [ -f .env ] && [[ "$force" != true ]]; then
    echo ".env already exists — keeping it (use './run env -f' to replace from .env.example)"
    chmod 664 .env 2>/dev/null || true
    fix_host_env_files_owner
    return 0
  fi

  if [ -f .env ]; then
    echo "Overwriting .env from .env.example (-f/--force)"
  else
    echo "Creating .env from .env.example"
  fi
  cp -f .env.example .env
  chmod 664 .env
  fix_host_env_files_owner
}

function get_compose_file {
  if [[ -n "${E_MUSEU_COMPOSE_FILE:-}" ]]; then
    echo "$E_MUSEU_COMPOSE_FILE"
    return 0
  fi
  source .env
  if [ "$APP_ENV" == "production" ]; then
    echo "docker-compose.prod-local.yml"
  elif [ "$APP_ENV" == "staging" ]; then
    echo "docker-compose.prod-local.yml"
  elif [ "$APP_ENV" == "local" ]; then
    echo "docker-compose.local.yml"
  elif [[ "$1" == "--no-check" ]]; then
    echo $APP_ENV
  else
    echo "Error: APP_ENV must be 'local', 'staging' or 'prod-local'. Current value: '$APP_ENV'" >&2
    exit 1
  fi
}

function setup {
  echo "Running setup..."

  env || echo "[warn] Failed to ensure .env (env); continuing..."

  source .env
  compose_file=$(get_compose_file)
  echo ""
  echo "=================================================="
  if [ "$compose_file" == "docker-compose.local.yml" ]; then
    echo "    RUNNING IN LOCAL ENVIRONMENT"
  elif [ "$compose_file" == "docker-compose.prod-local.yml" ]; then
    if [ "$APP_ENV" == "staging" ]; then
      echo "    RUNNING IN STAGING (same stack as prod-local)"
    else
      echo "    RUNNING IN PRODUCTION SIMULATION (LOCAL)"
    fi
  else
    echo "    ERROR: UNKNOWN ENVIRONMENT"
    echo "    APP_ENV value: $(source .env && echo $APP_ENV)"
    echo "    Please check your .env file and set APP_ENV to 'local', 'staging' or 'prod-local'"
  fi
  echo "    Docker Compose: $compose_file"
  echo "=================================================="
  echo ""

  up || echo "[warn] Failed to start containers (up); continuing..."

  composer || echo "[warn] Composer install failed (composer); continuing..."

  echo ">> Fixing permissions (bootstrap/cache, storage, .env, PHPUnit cache)..."
  # Dockerfile.local uses user laravel; Dockerfile.prod-local uses www-data only — chown must match.
  # Vendor is not chown'd: tests only read it; recursive chown there is slow and unnecessary for PHPUnit.
  docker compose -f "$(get_compose_file)" exec -u root app sh -c '
    mkdir -p /var/www/storage/logs /var/www/storage/framework/sessions /var/www/storage/framework/views /var/www/storage/framework/cache
    if id laravel >/dev/null 2>&1; then
      OWNER=laravel
    else
      OWNER=www-data
    fi
    chown -R "$OWNER:www-data" /var/www/bootstrap/cache /var/www/storage
    if [ -f /var/www/.env ]; then
      chown "$OWNER:www-data" /var/www/.env
      chmod 664 /var/www/.env
    fi
    if [ -f /var/www/.phpunit.result.cache ]; then
      chown "$OWNER:www-data" /var/www/.phpunit.result.cache
    fi
  '

  if [ "$APP_ENV" == "local" ]; then
    echo ">> Preparing Vite (compose vite service + npm install)..."
    npm-local-bg || echo "[warn] Failed to prepare Vite in container; continuing..."
    ensure-vite-assets-local || echo "[warn] Failed to ensure Vite assets (hot/manifest); continuing..."
  fi

  if [[ "$1" == "-y" || "$2" == "-y" ]]; then
    gen_key_if_missing -y || echo "[warn] Key generation failed (gen_key_if_missing); continuing..."
  else
    gen_key_if_missing || echo "[warn] Key generation failed (gen_key_if_missing); continuing..."
  fi

  migrate || echo "[warn] Migrations failed (migrate); continuing..."

  seed || echo "[warn] Seeding failed (seed); continuing..."

  echo ">> Fixing host ownership of .env and .phpunit.result.cache (editable in your editor)..."
  fix_host_env_files_owner
}

function setup-hard {
  local has_y=false
  local keep_db=false
  for arg in "$@"; do
    case "$arg" in
      -y) has_y=true ;;
      -env) ;; # legacy no-op: setup always runs env (create .env from example if missing)
      -db) keep_db=true ;;
    esac
  done

  if [[ "$has_y" != true ]]; then
    echo "WARNING: You are about to run setup-hard."
    if [[ "$keep_db" == true ]]; then
      echo "This will remove node_modules, vendor, and all Docker containers, but keep mysql_data (local MySQL data volume)."
    else
      echo "This will delete and recreate your database, node_modules, vendor, and all Docker containers."
    fi
    echo -n "Proceed only if you are sure. (y/n): "
    read confirm

    if [ "$confirm" != "y" ]; then
      echo "Aborting setup-hard."
      exit 1
    fi
  fi

  echo "Running setup-hard..."

  if [[ "$keep_db" == true ]]; then
    remove-all -y -db || echo "[warn] Could not complete cleanup (remove-all); continuing..."
  else
    remove-all -y || echo "[warn] Could not complete cleanup (remove-all); continuing..."
  fi

  if [[ "$has_y" == true ]]; then
    setup -y || echo "[warn] Setup process failed (setup)."
  else
    setup || echo "[warn] Setup process failed (setup)."
  fi
}

function npm-local-bg {
  source .env
  if [ "$APP_ENV" != "local" ]; then
    echo "npm-local-bg can only be run in local environment. Current APP_ENV: $APP_ENV" >&2
    return 1
  fi

  echo ">> Ensuring Node.js dependencies in vite container..."
  docker compose -f "$(get_compose_file)" exec vite npm install

  # Vite is already started by docker-compose.local.yml (vite service command). Do not run a
  # second npm run dev here — it fights for port 5173 and can break public/hot.
  echo ">> Vite runs via the compose vite service (see vite.config.js server.origin for Docker)."
  echo "Access your site at: http://localhost:$(grep WEB_SERVER_PORT_LOCAL .env | cut -d'=' -f2)"
  echo "Access Vite dev server at: http://localhost:5173"
}

function stop-vite-local {
  source .env
  echo ">> Stopping Vite dev server..."

  echo ">> Removing public/hot and restarting vite container..."
  docker compose -f "$(get_compose_file)" exec app rm -rf public/hot 2>/dev/null || true
  docker compose -f "$(get_compose_file)" restart vite

  if [ $? -eq 0 ]; then
    echo "Vite container restarted - dev server stopped!"
  else
    echo "Failed to restart container"
    return 1
  fi
}

function start-vite-local {
  source .env
  if [ "$APP_ENV" != "local" ]; then
    echo "start-vite-local can only be run in local environment. Current APP_ENV: $APP_ENV" >&2
    return 1
  fi

  VITE_PORT=5173
  if curl -s http://localhost:$VITE_PORT > /dev/null 2>&1; then
    echo "Vite dev server is already running on port $VITE_PORT"
    echo "Access Vite at: http://localhost:$VITE_PORT"
    echo "Use './run stop-vite-local' to stop it first if you want to restart"
    return 0
  fi

  echo ">> Starting Vite dev server in background..."
  echo "Access your site at: http://localhost:$(grep WEB_SERVER_PORT_LOCAL .env | cut -d'=' -f2)"
  echo ""

  docker compose -f "$(get_compose_file)" exec -d vite npm run dev -- --host 0.0.0.0 --port $VITE_PORT
  
  echo "Vite dev server started successfully!"
  echo "Access Vite at: http://localhost:$VITE_PORT"
}

function build-vite {
  source .env
  echo ">> Removing old build files..."
  docker compose -f "$(get_compose_file)" exec app rm -rf public/build public/hot 2>/dev/null || true
  echo ">> Building assets with Vite for production..."
  docker compose -f "$(get_compose_file)" exec vite npm run build
}

# After setup-hard, public/build and public/hot are gone. Local setup relies on the Vite dev
# server writing public/hot; if that is slow or fails, Laravel falls back to manifest.json
# and throws ViteManifestNotFoundException. We wait for hot or manifest, then build if needed.
function ensure-vite-assets-local {
  source .env
  if [ "$APP_ENV" != "local" ]; then
    return 0
  fi

  local compose_file
  compose_file=$(get_compose_file)
  echo ">> Waiting for Vite assets (public/hot from dev server or public/build/manifest.json)..."
  local i=0
  while [ $i -lt 90 ]; do
    if [ -f public/hot ] || [ -f public/build/manifest.json ]; then
      echo ">> Vite assets ready."
      return 0
    fi
    sleep 2
    i=$((i + 1))
  done

  echo ">> Timed out waiting for Vite; running npm run build (creates manifest.json)..."
  docker compose -f "$compose_file" exec vite npm run build
}

function seed {
  source .env
  echo ">> Seeding database..."
  docker compose -f "$(get_compose_file)" exec app php artisan db:seed --force
}

function phpstan {
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpstan analyse --memory-limit=1G --configuration=phpstan.neon
  else
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpstan analyse --memory-limit=1G --configuration=phpstan.neon ${TEST_PATH}
  fi
}

function phpcs {
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpcs --standard=phpcs.xml
  else
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpcs --standard=phpcs.xml ${TEST_PATH}
  fi
}

function phpcbf {
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpcbf --standard=phpcs.xml
  else
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpcbf --standard=phpcs.xml ${TEST_PATH}
  fi
}

function pint {
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    # Limit Pint to source directories to avoid scanning mysql_data and other volumes
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/pint app config database routes tests
  else
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/pint ${TEST_PATH}
  fi
}

function pint-test {
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    # Same limited scope for test mode
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/pint --test app config database routes tests
  else
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/pint --test ${TEST_PATH}
  fi
}

function phpinsights {
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpinsights
  else
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpinsights ${TEST_PATH}
  fi
}

function phpcpd {
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm app php ./vendor/systemsdk/phpcpd/phpcpd app routes tests
  else
    docker compose -f "$(get_compose_file)" run --rm app php ./vendor/systemsdk/phpcpd/phpcpd ${TEST_PATH}
  fi
}

function churn {
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/churn run app routes tests
  else
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/churn run ${TEST_PATH}
  fi
}

function phpmd {
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpmd app,routes,tests text phpmd.xml
  else
    docker compose -f "$(get_compose_file)" run --rm app ./vendor/bin/phpmd ${TEST_PATH} text phpmd.xml
  fi
}

function eslint {
  source .env
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm vite npm run lint
  else
    docker compose -f "$(get_compose_file)" run --rm vite npx eslint ${TEST_PATH}
  fi
}

function eslint-fix {
  source .env
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm vite npm run lint:fix
  else
    docker compose -f "$(get_compose_file)" run --rm vite npx eslint ${TEST_PATH} --fix
  fi
}

function prettier {
  source .env
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm vite npm run format
  else
    docker compose -f "$(get_compose_file)" run --rm vite npx prettier --write ${TEST_PATH}
  fi
}

function prettier-check {
  source .env
  TEST_PATH="${@:-}"
  if [ -z "$TEST_PATH" ]; then
    docker compose -f "$(get_compose_file)" run --rm vite npm run format:check
  else
    docker compose -f "$(get_compose_file)" run --rm vite npx prettier --check ${TEST_PATH}
  fi
}

function ensure-mysql-testing-database {
  source .env
  local compose_file
  compose_file=$(get_compose_file)

  if [[ "$DB_CONNECTION" != "mysql" ]]; then
    return 0
  fi

  if [[ "$compose_file" != "docker-compose.local.yml" && "$compose_file" != "docker-compose.prod-local.yml" ]]; then
    return 0
  fi

  echo ">> Ensuring MySQL database emuseu_testing exists and is granted to application user (MYSQL_USER in db container, from .env DB_USERNAME)..."
  # Password and app user are expanded only inside the db container (see docker-compose MYSQL_* env), not passed as -p on the host shell.
  if ! docker compose -f "$compose_file" exec -T db sh -c "
    mysql -uroot -p\"\$MYSQL_ROOT_PASSWORD\" mysql -e 'CREATE DATABASE IF NOT EXISTS emuseu_testing CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;' &&
    mysql -uroot -p\"\$MYSQL_ROOT_PASSWORD\" mysql -e \"GRANT ALL PRIVILEGES ON emuseu_testing.* TO '\$MYSQL_USER'@'%';\" &&
    mysql -uroot -p\"\$MYSQL_ROOT_PASSWORD\" mysql -e 'FLUSH PRIVILEGES;'
  "; then
    echo "ERROR: Could not create or grant emuseu_testing. Is the db container up? Check MYSQL_ROOT_PASSWORD and MYSQL_USER in the container (from .env DB_ROOT_PASSWORD / DB_USERNAME)." >&2
    return 1
  fi
}

function test {
  ensure-mysql-testing-database
  docker compose -f "$(get_compose_file)" exec app php artisan test
}

function all-tests {
  set -e
  echo "===="
  echo ">> Running PHPUnit tests..."
  echo "===="
  ./run test
  echo "===="
  echo ">> Running PHP Code Sniffer (phpcs)..."
  echo "===="
  ./run phpcs
  echo "===="
  echo ">> Running Laravel Pint (style check)..."
  echo "===="
  ./run pint-test
  echo "===="
  echo ">> Running PHP Mess Detector (phpmd)..."
  echo "===="
  ./run phpmd
  echo "===="
  echo ">> Running PHPStan..."
  echo "===="
  ./run phpstan
  echo "===="
  echo ">> Running PHP Copy/Paste Detector (phpcpd)..."
  echo "===="
  ./run phpcpd
  echo "===="
  echo ">> Running ESLint..."
  echo "===="
  ./run eslint
  echo "===="
  echo ">> Running Prettier check..."
  echo "===="
  ./run prettier-check
}

function all-fix {
  set -e
  echo "===="
  echo ">> Running PHP Code Beautifier and Fixer (phpcbf)..."
  echo "===="
  ./run phpcbf
  echo "===="
  echo ">> Running Laravel Pint (PHP code style fixer)..."
  echo "===="
  ./run pint
  echo "===="
  echo ">> Running ESLint with auto-fix..."
  echo "===="
  ./run eslint-fix
  echo "===="
  echo ">> Running Prettier (format JS/SASS/JSON)..."
  echo "===="
  ./run prettier
}

function ps {
  docker compose -f "$(get_compose_file)" ps "${@}"
}

function up {
  source .env
  docker compose -f "$(get_compose_file)" up -d "${@}"
}

function down {
  docker compose -f "$(get_compose_file)" down "${@}"
}

function gen_key_if_missing {
  source .env
  if [[ -n "${APP_KEY:-}" ]]; then
    echo ">> APP_KEY already set — skipping key:generate"
    return 0
  fi
  echo ">> Generating application key..."
  if [[ "$1" == "-y" ]]; then
    docker compose -f "$(get_compose_file)" exec app php artisan key:generate --force
  else
    docker compose -f "$(get_compose_file)" exec app php artisan key:generate
  fi
}

function gen_key {
  source .env
  echo ">> Generating application key..."
  if [[ "$1" == "-y" ]]; then
    docker compose -f "$(get_compose_file)" exec app php artisan key:generate --force
  else
    docker compose -f "$(get_compose_file)" exec app php artisan key:generate
  fi
}

function wait-for-db {
  source .env
  echo ">> Waiting for database to be ready..."
  local max_attempts=30
  local attempt=1
  
  while [ $attempt -le $max_attempts ]; do
    # Test connection from app container to db container using PHP PDO
    if docker compose -f "$(get_compose_file)" exec -T app php -r "try { \$pdo = new PDO('mysql:host=db;port=3306', '${DB_USERNAME}', '${DB_PASSWORD}'); \$pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION); exit(0); } catch (Exception \$e) { exit(1); }" 2>/dev/null; then
      echo "  Database is ready!"
      return 0
    fi
    
    if [ $attempt -lt $max_attempts ]; then
      echo "  Waiting for database... (attempt $attempt/$max_attempts)"
      sleep 2
    fi
    
    attempt=$((attempt + 1))
  done
  
  echo "  ERROR: Database did not become ready after $max_attempts attempts"
  return 1
}

function migrate {
  source .env
  wait-for-db
  echo ">> Running database migrations..."
  docker compose -f "$(get_compose_file)" exec app php artisan migrate --force
}

function composer {
  source .env
  echo ">> Configuring Git safe.directory for /var/www..."
  docker compose -f "$(get_compose_file)" exec app git config --global --add safe.directory /var/www 2>/dev/null || true
  echo ">> Installing Composer dependencies (as root to avoid permission issues)..."
  docker compose -f "$(get_compose_file)" exec -u root app sh -c 'php -d error_reporting="E_ALL&~E_DEPRECATED&~E_USER_DEPRECATED" /usr/bin/composer install --no-interaction --optimize-autoloader'
}

function remove-all {
  local has_y=false
  local keep_db=false
  for arg in "$@"; do
    case "$arg" in
      -y) has_y=true ;;
      -db) keep_db=true ;;
    esac
  done

  if [[ "$has_y" != true ]]; then
    echo "WARNING: You are about to run remove-all."
    if [[ "$keep_db" == true ]]; then
      echo "This will remove node_modules, vendor, and all Docker containers, but keep mysql_data (local MySQL data volume)."
    else
      echo "This will delete and recreate your production database, node_modules, vendor, and all Docker containers."
    fi
    echo -n "Proceed only if you are sure. (y/n): "
    read confirm

    if [ "$confirm" != "y" ]; then
      echo "Aborting setup-production-hard."
      exit 1
    fi
  fi

  local file_args=(-y)
  [[ "$keep_db" == true ]] && file_args+=(-db)
  remove-all-files "${file_args[@]}" || echo "[warn] Could not complete file cleanup (remove-all-files); continuing..."

  remove-all-docker || echo "[warn] Could not complete Docker cleanup (remove-all-docker); continuing..."

  echo ">> Cleanup completed!"
}

function remove-all-files {
  local has_y=false
  local keep_db=false
  for arg in "$@"; do
    case "$arg" in
      -y) has_y=true ;;
      -db) keep_db=true ;;
    esac
  done

  if [[ "$has_y" != true ]]; then
    echo "WARNING: You are about to run remove-all-files."
    if [[ "$keep_db" == true ]]; then
      echo "This will delete vendor, node_modules, public/hot and public/build (mysql_data is kept)."
    else
      echo "This will delete mysql_data, vendor, node_modules, public/hot and public/build."
    fi
    echo -n "Proceed only if you are sure. (y/n): "
    read confirm

    if [ "$confirm" != "y" ]; then
      echo "Aborting setup-production-hard."
      exit 1
    fi
  fi

  if [[ "$keep_db" == true ]]; then
    echo ">> Removing vendor, node_modules, public/hot and public/build (keeping mysql_data)..."
  else
    echo ">> Removing mysql_data, vendor, node_modules, public/hot and public/build..."
    rm -rf mysql_data 2>/dev/null || echo "mysql_data directory not found, skipping removal"
  fi

  rm -rf vendor 2>/dev/null || echo "vendor directory not found, skipping removal"
  rm -rf node_modules 2>/dev/null || echo "node_modules directory not found, skipping removal"
  rm -rf public/hot 2>/dev/null || echo "public/hot file not found, skipping removal"
  rm -rf public/build 2>/dev/null || echo "public/build file not found, skipping removal"

  echo ">> File cleanup completed!"
}

function remove-all-docker {
  echo ">> Removing all Docker containers, images, and volumes..."

  docker ps -a --filter "name=e-museu" -q | xargs -r docker rm -f

  docker images --format "{{.Repository}}:{{.Tag}} {{.ID}}" | grep "e-museu" | awk '{print $2}' | xargs -r docker rmi -f

  docker volume ls --format "{{.Name}}" | grep "e-museu" | xargs -r docker volume rm -f
}

function exec {
  source .env
  if [ $# -eq 0 ]; then
    echo ">> Missing command to run inside app container"
    exit 1
  fi

  echo ">> Executing in app container: $*"
  sudo docker exec -it e-museu-app-1 "$@"
}

function version {
  echo "E-Museu $(cat VERSION)"
}

# simulate-ci runs scripts/ci/* : jobs 1–2 source prepare-ci-compose.sh (down local+prod-local, then
# E_MUSEU_COMPOSE_FILE=docker-compose.local.yml like GitHub Actions). Job 3 is production deploy smoke test.
# Unset E_MUSEU_COMPOSE_FILE when done if you want ./run to follow APP_ENV again.
function simulate-ci {
  set -e
  
  echo "=========================================="
  echo "Simulating CI Pipeline"
  echo "=========================================="
  echo ""
  echo "This will run all CI jobs in sequence:"
  echo "  1. tests"
  echo "  2. code-quality"
  echo "  3. test-production-deploy"
  echo ""
  echo "Jobs 1–2: compose down (local + prod-local), then docker-compose.local.yml + ./run setup -y (same as CI)."
  echo "Each job ends with ./run down. Afterward: unset E_MUSEU_COMPOSE_FILE; ./run up uses APP_ENV from .env again."
  echo ""
  
  if [[ "$1" != "-y" && "$2" != "-y" ]]; then
    echo -n "Proceed? (y/n): "
    read confirm
    if [ "$confirm" != "y" ]; then
      echo "Aborted."
      exit 0
    fi
  fi
  
  echo ""
  echo "=========================================="
  echo "Job 1/3: tests"
  echo "=========================================="
  if [ -f "./scripts/ci/ci-tests.sh" ]; then
    ./scripts/ci/ci-tests.sh
  else
    echo "ERROR: scripts/ci/ci-tests.sh not found"
    exit 1
  fi
  
  echo ""
  echo "=========================================="
  echo "Job 2/3: code-quality"
  echo "=========================================="
  if [ -f "./scripts/ci/ci-code-quality.sh" ]; then
    ./scripts/ci/ci-code-quality.sh
  else
    echo "ERROR: scripts/ci/ci-code-quality.sh not found"
    exit 1
  fi
  
  echo ""
  echo "=========================================="
  echo "Job 3/3: test-production-deploy"
  echo "=========================================="
  if [ -f "./scripts/ci/ci-test-production-deploy.sh" ]; then
    ./scripts/ci/ci-test-production-deploy.sh
  else
    echo "ERROR: scripts/ci/ci-test-production-deploy.sh not found"
    exit 1
  fi
  
  echo ""
  echo "=========================================="
  echo "✓ All CI jobs completed successfully!"
  echo "=========================================="
}

function help {
  echo "Usage: run [command] [options]"
  echo ""
  echo "Environments (APP_ENV in .env):"
  echo "  local      - docker-compose.local.yml (Vite dev server, db, seed, phpMyAdmin)"
  echo "  staging    - Same as prod-local: docker-compose.prod-local.yml (no Vite dev server)"
  echo "  prod-local - docker-compose.prod-local.yml (production-like stack locally)"
  echo ""
  echo "Environment & Setup:"
  echo "  env                - Ensure .env exists (copy from .env.example only if missing)"
  echo "  env -f             - Force: replace .env from .env.example (same as --force)"
  echo "  setup              - Full setup (ensures .env if missing, up, composer, key if needed, migrate, seed)"
  echo "  setup -y           - Same with automatic confirmation (skips key:generate if APP_KEY set)"
  echo "  setup-hard         - Hard reset then setup (same .env rules as setup)"
  echo "  setup-hard -y      - Hard reset without confirmation prompt"
  echo "  setup-hard -db     - Hard reset but keep mysql_data (local DB volume); combine with -y: setup-hard -y -db"
  echo "  up                 - Start Docker containers"
  echo "  down               - Stop Docker containers"
  echo "  ps                 - Show container status"
  echo "  remove-all         - Clean up environment (remove mysql_data, vendor, containers, images, volumes)"
  echo "  remove-all -db     - Same as remove-all but keep mysql_data (pass with -y: remove-all -y -db)"
  echo "  remove-all-files   - Remove only files (mysql_data, vendor, node_modules, public/hot, public/build)"
  echo "  remove-all-files -db - Same but keep mysql_data (e.g. remove-all-files -y -db)"
  echo "  remove-all-docker  - Remove only Docker containers, images, and volumes"
  echo ""
  echo "Node.js & Vite (local only; staging/prod-local use built assets):"
  echo "  npm-local-bg       - Install npm dependencies and start Vite dev server in background"
  echo "  stop-vite-local    - Stop Vite dev server"
  echo "  start-vite-local   - Start Vite dev server in background"
  echo "  build-vite         - Build assets with Vite for production"
  echo ""
  echo "Laravel Commands:"
  echo "  gen_key            - Generate or replace Laravel APP_KEY (always writes .env)"
  echo "  gen_key -y         - Same with --force (no prompt in production-like envs)"
  echo "  migrate            - Run database migrations"
  echo "  seed               - Seed database with initial data"
  echo "  composer           - Install Composer dependencies"
  echo ""
  echo "Testing & Code Quality:"
  echo "  NOTE: Before running code quality tools:"
  echo "        1. Ensure APP_ENV=local is set in your .env file"
  echo "        2. Run './run setup' to start containers and ensure vendor directory is"
  echo "           properly mounted and binaries are available."
  echo ""
  echo "  test               - Run PHPUnit tests"
  echo "  phpstan            - Run PHPStan static analysis (Level 5 with Larastan)"
  echo "  phpstan <path>     - Run PHPStan on specific path"
  echo "  phpcs              - Run PHP Code Sniffer (PSR-12 standards)"
  echo "  phpcs <path>       - Run PHP Code Sniffer on specific path"
  echo "  phpcbf             - Run PHP Code Beautifier and Fixer"
  echo "  phpcbf <path>      - Run PHP Code Beautifier and Fixer on specific path"
  echo "  pint               - Run Laravel Pint (PHP code style fixer, including unused imports)"
  echo "  pint <path>        - Run Laravel Pint on specific path"
  echo "  pint-test          - Run Laravel Pint in test mode (check only, no changes)"
  echo "  pint-test <path>   - Run Laravel Pint test on specific path"
  echo "  phpinsights        - Run PHP Insights code quality analysis"
  echo "  phpinsights <path> - Run PHP Insights on specific path"
  echo "  phpcpd             - Detect duplicated PHP code (Copy/Paste Detector)"
  echo "  phpcpd <path>     - Detect duplicated code on specific path"
  echo "  churn              - Analyze PHP files for refactoring candidates (files with high change frequency)"
  echo "  churn <path>      - Analyze specific path for refactoring candidates"
  echo "  phpmd              - Run PHP Mess Detector (detect code smells and design issues)"
  echo "  phpmd <path>      - Run PHP Mess Detector on specific path"
  echo "  eslint            - Run ESLint on JavaScript files"
  echo "  eslint <path>    - Run ESLint on specific path"
  echo "  eslint-fix       - Run ESLint with auto-fix on JavaScript files"
  echo "  eslint-fix <path> - Run ESLint with auto-fix on specific path"
  echo "  prettier         - Format JavaScript, SASS, and JSON files with Prettier"
  echo "  prettier <path>  - Format specific path with Prettier"
  echo "  prettier-check   - Check if files are formatted correctly (without modifying)"
  echo "  prettier-check <path> - Check specific path formatting"
  echo "  all-tests          - Run all checks (test, phpcs, pint-test, phpmd, phpstan, phpcpd, eslint, prettier-check)"
  echo "  all-fix           - Run all auto-fix tools (phpcbf, pint, eslint-fix, prettier)"
  echo "  simulate-ci        - Simulate complete CI pipeline (runs all CI jobs)"
  echo "  simulate-ci -y     - Simulate CI pipeline without confirmation"
  echo ""
  echo "Utilities:"
  echo "  exec <cmd>         - Execute command inside app container"
  echo "  help               - Show this help message"
  echo "  version            - Show E-Museu version"
  echo ""
  echo "Examples:"
  echo "  ./run setup                # Setup (creates .env from example only if missing)"
  echo "  ./run setup -y             # Setup non-interactive; keeps existing APP_KEY if set"
  echo "  ./run setup-hard -y -db    # Hard reset, keep mysql_data and your .env / APP_KEY"
  echo "  ./run gen_key -y           # Generate app key without confirmation"
  echo "  ./run test                 # Run tests"
  echo "  ./run all-tests            # Run all checks (test, phpcs, pint-test, phpmd, phpstan, phpcpd, eslint, prettier)"
  echo "  ./run phpstan app/Models   # Analyze specific directory"
  echo "  ./run phpcs app/Models     # Check code style on specific directory"
  echo "  ./run phpcbf app/Models    # Fix code style on specific directory"
  echo "  ./run phpinsights app/Models  # Run code quality analysis on specific directory"
  echo "  ./run phpcpd app/Models       # Detect duplicated code in specific directory"
  echo "  ./run churn app/Models        # Analyze files for refactoring candidates"
  echo "  ./run phpmd app/Models        # Detect code smells and design issues"
  echo "  ./run eslint resources/js    # Lint JavaScript files"
  echo "  ./run eslint-fix resources/js  # Fix JavaScript code style automatically"
  echo "  ./run prettier resources/js   # Format JavaScript files"
  echo "  ./run prettier-check          # Check if files are formatted"
  echo "  ./run simulate-ci            # Simulate complete CI pipeline"
  echo "  ./run simulate-ci -y         # Simulate CI pipeline without confirmation"
  echo "  ./run exec php artisan tinker  # Open Laravel tinker"
  echo "  ./run remove-all -y        # Remove all without confirmation prompt"
  echo "  ./run remove-all -y -db    # Full cleanup but keep mysql_data"
  echo ""
  echo "Options:"
  echo "  -y                 - Skip confirmation prompts (works with setup, setup-hard, gen_key, remove-all, remove-all-files)"
  echo "  -env               - Ignored (kept for old scripts): setup always ensures .env if missing"
  echo "  -db                - Keep mysql_data (local Docker MySQL volume); use with setup-hard, remove-all, or remove-all-files"
}

